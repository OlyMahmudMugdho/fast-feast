# Database Configuration
# Use postgres:alpine with Docker
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/fastfeast_db

# Stripe Configuration (Modern V2 Connect)
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Subscription ID for Shop 'Visibility Boost' feature
# Create a recurring price in Stripe and paste the ID here
STRIPE_SUBSCRIPTION_PRICE_ID=price_...

# Platform Configuration
FRONTEND_URL=http://localhost:8000
STRIPE_SUCCESS_URL=http://localhost:8000/buyer/orders?success=true
STRIPE_CANCEL_URL=http://localhost:8000/buyer/dashboard?canceled=true
PLATFORM_FEE_PERCENT=0.10

# Media Storage (Cloudinary)
# Format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Security
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
